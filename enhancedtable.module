<?php

/**
 * @file
 * Enhanced Table module bootstrap.
 */

/**
 * Implements hook_views_api().
 */
function enhancedtable_views_api() {
  return array(
    'api' => '3.0',
    'path' => backdrop_get_path('module', 'enhancedtable') . '/views',
  );
}

/**
 * Implements hook_autoload_info().
 *
 * Ensure the Views style plugin class file is loaded when needed.
 */
function enhancedtable_autoload_info() {
  return array(
    'enhancedtable_plugin_style_table' => 'views/enhancedtable_plugin_style_table.inc',
  );
}

/**
 * Implements hook_library_info().
 *
 * Currently unused by the style options form, but kept for future styling.
 */
function enhancedtable_library_info() {
  $path = backdrop_get_path('module', 'enhancedtable');
  return array(
    'enhancedtable.admin' => array(
      'title' => 'EnhancedTable admin helpers',
      'version' => '1.x',
      'js' => array(
        $path . '/js/enhancedtable.admin.js' => array(),
      ),
      'css' => array(
        $path . '/css/enhancedtable.admin.css' => array(
          'type'  => 'file',
          'group' => CSS_THEME,
        ),
      ),
    ),
  );
}

/**
 * Implements hook_theme().
 *
 * Provide a custom theme function for the table-style options form in Views.
 */
function enhancedtable_theme($existing, $type, $theme, $path) {
  return array(
    'enhancedtable_flipped_options_table' => array(
      'render element' => 'form',
      'file' => 'views/enhancedtable.admin.inc',
    ),
    // Custom Views UI theme for the table style plugin options form.
    // EnhancedTable replaces the stock table-matrix UI with a cards-based UI.
    'enhancedtable_views_ui_style_plugin_table' => array(
      'render element' => 'form',
      'file' => 'views/enhancedtable.admin.inc',
    ),
  );
}

/**
 * Preprocess for views_view_table: EnhancedTable extras (widths, borders).
 */
function enhancedtable_preprocess_views_view_table(&$variables) {
  // Shared helper functions.
  module_load_include('inc', 'enhancedtable', 'includes/enhancedtable.shared');

  $view = $variables['view'];

  // Only act on views using our EnhancedTable style plugin.
  $plugin_name = !empty($view->style_plugin->plugin_name)
    ? $view->style_plugin->plugin_name
    : '';
  // We're looking for 'enhancedtable' as defined in file:enhancedtable.views.inc
  if ($plugin_name !== 'enhancedtable') {
    return;
  }

  $options = $view->style_plugin->options;

  // Selector for ONLY this display's own root table (no bleed into embedded views).
  $table_selector = enhancedtable_get_root_table_selector($view);

  $css = enhancedtable_build_table_css($options, $table_selector);
  if ($css !== '') {
    backdrop_add_css($css, array('type' => 'inline'));
  }
}

